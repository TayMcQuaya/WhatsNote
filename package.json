{
  "name": "whatsnote",
  "version": "1.0.0",
  "description": "WhatsApp-style conversational to-do app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.whatsnote.app",
    "productName": "WhatsNote",
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ]
  }
}
